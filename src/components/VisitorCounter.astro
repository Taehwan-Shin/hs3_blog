---

<div class="mt-4 flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-[10px] uppercase tracking-widest text-primary-400 dark:text-primary-500 font-medium" id="visitor-counter-container">
  <span class="flex items-center gap-1.5">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    <span>오늘 <span id="daily-views-count">...</span>명</span>
  </span>
  <span class="hidden sm:inline opacity-30 text-primary-300">|</span>
  <span class="flex items-center gap-1.5">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
    <span>누적 <span id="total-views-count">...</span>회</span>
  </span>
</div>

<script>
  import { db } from '../lib/firebase';
  import { ref, runTransaction, get } from 'firebase/database';

  async function updateGlobalStats() {
    const dailyViewsText = document.getElementById('daily-views-count');
    const totalViewsText = document.getElementById('total-views-count');
    if (!dailyViewsText || !totalViewsText) return;

    // Get today's date in KST (Korean Standard Time)
    const kstDate = new Date(new Date().getTime() + 9 * 60 * 60 * 1000).toISOString().split('T')[0];
    
    // Firebase References
    const dailyRef = ref(db, `views/global/daily/${kstDate}`);
    const totalRef = ref(db, `views/global/total`);

    // 1. Total Page Views (PV) - Increment on every page load
    runTransaction(totalRef, (currentValue) => {
      return (currentValue || 0) + 1;
    }).then((result) => {
      if (result.committed) {
        totalViewsText.textContent = result.snapshot.val().toLocaleString();
      }
    });

    // 2. Daily Unique Visitors (UV) - Increment only once per day per user
    const hasVisitedToday = localStorage.getItem('hs3_visited_date') === kstDate;

    if (!hasVisitedToday) {
      runTransaction(dailyRef, (currentValue) => {
        return (currentValue || 0) + 1;
      }).then((result) => {
        if (result.committed) {
          dailyViewsText.textContent = result.snapshot.val().toLocaleString();
          localStorage.setItem('hs3_visited_date', kstDate); // Mark as visited today
        }
      });
    } else {
      // If already visited, just fetch and display the current daily count
      get(dailyRef).then((snapshot) => {
        const val = snapshot.val() || 0;
        dailyViewsText.textContent = val.toLocaleString();
      });
    }
  }

  // Initial load
  updateGlobalStats();
  
  // Support Swup page transitions
  document.addEventListener('swup:content:replace', updateGlobalStats);
</script>
