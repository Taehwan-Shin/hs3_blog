
---
import Icon from './Icon.astro';
---

<div class="mt-4 flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-[10px] uppercase tracking-widest text-primary-400 dark:text-primary-500 font-medium" id="visitor-counter-container">
  <span class="flex items-center gap-1.5">
    <Icon name="eye" class="w-3 h-3" />
    <span>누적 방문 <span id="total-views-count">...</span>회</span>
  </span>
</div>

<script>
  import { db } from '../lib/firebase';
  import { ref, onValue, runTransaction } from 'firebase/database';

  async function updateGlobalStats() {
    const totalViewsText = document.getElementById('total-views-count');
    if (!totalViewsText) return;

    // Path in Firebase: views/global/total
    const globalRef = ref(db, `views/global/total`);

    // Only increment once per session to avoid inflated counts on refresh?
    // For now, let's just count every page load as a hit (standard PV)
    runTransaction(globalRef, (currentValue) => {
      return (currentValue || 0) + 1;
    }).then((result) => {
      if (result.committed) {
        totalViewsText.textContent = result.snapshot.val().toLocaleString();
      }
    });
  }

  // Initial load
  updateGlobalStats();
  
  // Support Swup
  document.addEventListener('swup:content:replace', updateGlobalStats);
</script>
